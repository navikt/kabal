{
  "name": "server",
  "description": "",
  "version": "1.0.0",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "start": "node --watch --trace-warnings -r dotenv-flow/config --es-module-specifier-resolution=node dist/cluster.js",
    "build": "bun build ./src/cluster.ts --target node --format esm --sourcemap --outdir dist",
    "dev:build": "npm run build -- --watch",
    "dev:start": "npm run start",
    "lint": "eslint ./src/**/*.ts --color --cache --cache-strategy content --cache-location .eslintcache",
    "typecheck": "tsc --no-emit"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/http-proxy": "^9.5.0",
    "dotenv-flow": "4.1.0",
    "fastify": "^4.28.0",
    "jose": "5.4.1",
    "openid-client": "5.6.5",
    "prom-client": "15.1.2"
  },
  "devDependencies": {
    "@eslint/js": "9.5.0",
    "@types/bun": "1.1.5",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "eslint": "8.57.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-prettier": "5.1.3",
    "globals": "15.6.0",
    "rollup": "^4.18.0",
    "typescript": "5.5.2",
    "typescript-eslint": "7.13.1"
  }
}